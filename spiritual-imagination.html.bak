<script>
// Typing animation
const words=['Custom Mugs','Personalized Gifts','T-Shirt Printing','Trophies & Awards','MDF Art'];
let wi=0,ci=0,deleting=false;
const el=document.getElementById('typingWord');
function type(){
  const w=words[wi];
  if(!deleting){
    el.textContent=w.slice(0,++ci);
    if(ci===w.length){deleting=true;setTimeout(type,2000);return}
  }else{
    el.textContent=w.slice(0,--ci);
    if(ci===0){deleting=false;wi=(wi+1)%words.length;setTimeout(type,400);return}
  }
  setTimeout(type,deleting?60:90);
}
setTimeout(type,800);

// Scroll animations
const obs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible')}});
},{threshold:0.12,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.fade-up').forEach((el,i)=>{
  el.style.transitionDelay=(i%4)*0.08+'s';
  obs.observe(el);
});

// Active nav highlight
const sections=document.querySelectorAll('section[id]');
const navAs=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let cur='';
  sections.forEach(s=>{if(window.scrollY>=s.offsetTop-120)cur=s.id});
  navAs.forEach(a=>{
    a.classList.toggle('active',a.getAttribute('href')==='#'+cur);
  });
},{passive:true});

// Mobile menu
function toggleMenu(){
  document.getElementById('hamburger').classList.toggle('open');
  document.getElementById('mobileMenu').classList.toggle('open');
}
function closeMobileMenu(){
  document.getElementById('hamburger').classList.remove('open');
  document.getElementById('mobileMenu').classList.remove('open');
}
</script>
